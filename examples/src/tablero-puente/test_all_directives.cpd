    labels: ['Ene','Feb','Mar','Abr','May','Jun'],
    datasets: [
      {label:'Ventas 2024', data:[12,19,3,5,2,3], borderColor:'rgb(75,192,192)'},
      {label:'Ventas 2025', data:[5,15,20,30,25,35], borderColor:'rgb(255,99,132)'}
    ]
  },
  options: {responsive:true, plugins:{title:{display:true, text:'Trend'}}}
}
#end chart
'<hr/>
'<h2>Fase 4 — animaciones</h2>
'<h3>17. #anime — anime.js animaciones</h3>
#anime 500 200
container.innerHTML = '<div class="box" style="width:60px;height:60px;background:#ffd966;position:absolute;top:70px;left:30px;border-radius:8px"></div>';
anime({
    targets: container.querySelector('.box'),
    translateX: 380,
    rotate: '1turn',
    duration: 2000,
    direction: 'alternate',
    loop: true,
    easing: 'easeInOutQuad'
});
#end anime
'<h3>18. #manim — animaciones matemáticas (vía MathBox, estilo 3blue1brown)</h3>
#manim 600 400
mathbox.set('focus', 3);
var view = mathbox.cartesian({range:[[-3,3],[-2,2],[-2,2]], scale:[1.5,1,1]});
view.axis({axis:1, color:0xffffff}); view.axis({axis:2, color:0xffffff}); view.axis({axis:3, color:0xffffff});
view.area({width:64, height:64, axes:[1,2], live:true,
    expr:function(emit,x,y,i,j,t){emit(x, y, Math.sin(x + t*2)*Math.cos(y));},
    channels:3});
view.surface({shaded:true, color:0xffd966});
#end manim
'<hr/>
'<p>Total: <b>18 directivas</b> de visualización web disponibles.</p>
