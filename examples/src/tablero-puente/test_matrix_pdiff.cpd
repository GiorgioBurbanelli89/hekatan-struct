"Test 2 — escalando tamaño de matriz con pdiff inline
'<hr/>
N_1(ξ; η) = (1 - ξ)*(1 - η)/4
N_2(ξ; η) = (1 + ξ)*(1 - η)/4
N_3(ξ; η) = (1 + ξ)*(1 + η)/4
N_4(ξ; η) = (1 - ξ)*(1 + η)/4
'<h4>Test 1×1</h4>
M1(ξ; η) = [pdiff(N_1(ξ; η); ξ)]
'M1(0; 0) ='M1(0; 0)
'<h4>Test 1×2</h4>
M2(ξ; η) = [pdiff(N_1(ξ; η); ξ); pdiff(N_2(ξ; η); ξ)]
'M2(0; 0) ='M2(0; 0)
'<h4>Test 1×4</h4>
M4(ξ; η) = [pdiff(N_1(ξ; η); ξ); pdiff(N_2(ξ; η); ξ); pdiff(N_3(ξ; η); ξ); pdiff(N_4(ξ; η); ξ)]
'M4(0; 0) ='M4(0; 0)
'<h4>Test 2×2</h4>
M2x2(ξ; η) = [pdiff(N_1(ξ; η); ξ); pdiff(N_2(ξ; η); ξ)|pdiff(N_1(ξ; η); η); pdiff(N_2(ξ; η); η)]
'M2x2(0; 0) ='M2x2(0; 0)
'<h4>Test 2×4 (target)</h4>
dN(ξ; η) = [pdiff(N_1(ξ; η); ξ); pdiff(N_2(ξ; η); ξ); pdiff(N_3(ξ; η); ξ); pdiff(N_4(ξ; η); ξ)|pdiff(N_1(ξ; η); η); pdiff(N_2(ξ; η); η); pdiff(N_3(ξ; η); η); pdiff(N_4(ξ; η); η)]
'dN(0; 0) ='dN(0; 0)
